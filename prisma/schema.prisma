model Historical_Data {
  assetId   String
  timeframe Timeframe
  timestamp DateTime
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Int
  asset     Asset     @relation(fields: [assetId], references: [id])

  @@id([assetId, timeframe, timestamp])
}

